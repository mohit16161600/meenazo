# COD orders now use the same-origin Next.js route /api/cod (no PHP/CORS).
# Leave NEXT_PUBLIC_COD_API unset to use the default "/api/cod".

# CRM MySQL connection — fill with your real live-server DB credentials.
CRM_DB_HOST=127.0.0.1
CRM_DB_PORT=3306
CRM_DB_USER=your_db_user
CRM_DB_PASSWORD=your_db_password
CRM_DB_NAME=your_db_name
